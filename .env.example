# Telegram bot token from @BotFather. Without it the bot can't run;
# tick/digest commands fall back to printing messages to stdout.
TELEGRAM_BOT_TOKEN=

# ---- Schedule (WIB / UTC+7) ----
# HRTA usually publishes the new price around 11am WIB
TICK_TIMES=09:15,12:15,17:15
DIGEST_TIME=08:00

# ---- ntfy (optional) ----
# Users enable ntfy themselves with the /ntfy command; each gets a personal
# random topic on this server. Only change these if you self-host ntfy.
# NTFY_SERVER=https://ntfy.sh
# NTFY_TOKEN=

# ---- Tuning (optional, these are the defaults) ----
# REARM_BUFFER_PCT=0.5
# DIP_LOOKBACK_DAYS=14
# DIP_THRESHOLD_PCT=2
# DATA_DIR=data
